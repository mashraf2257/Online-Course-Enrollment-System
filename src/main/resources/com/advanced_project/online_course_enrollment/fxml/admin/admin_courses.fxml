<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="1000.0" prefWidth="1600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advanced_project.online_course_enrollment.controller.CourseManagementController">
   <children>
      <Pane layoutX="1370.0" layoutY="11.0" prefHeight="119.0" prefWidth="209.0">
         <children>
            <Button layoutX="39.0" layoutY="14.0" mnemonicParsing="false" onAction="#handleCreateCourse" prefHeight="56.0" prefWidth="163.0" styleClass="admin-button" text="+ Add New Course" />
         </children>
      </Pane>
      <Pane layoutX="49.0" layoutY="90.0" prefHeight="87.0" prefWidth="1526.0" styleClass="admin-card">
         <children>
            <HBox layoutX="30.0" layoutY="20.0" prefHeight="56.0" prefWidth="1489.0">
               <children>
                  <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefHeight="49.0" prefWidth="920.0" promptText="Search by CourseID or Name" styleClass="enrollment-search" />
                  <VBox prefHeight="56.0" prefWidth="64.0" />
                  <ComboBox fx:id="majorFilter" onAction="#handleFilterByMajor" opacity="0.65" prefHeight="50.0" prefWidth="181.0" promptText="Filter by Major" />
                  <VBox prefHeight="56.0" prefWidth="0.0" />
                  <VBox prefHeight="56.0" prefWidth="87.0" />
                  <ComboBox fx:id="statusFilter" onAction="#handleFilterByStatus" opacity="0.65" prefHeight="52.0" prefWidth="196.0" promptText="Filter by Status" />
               </children>
            </HBox>
         </children>
      </Pane>
      <VBox layoutX="44.0" layoutY="193.0" prefHeight="650.0" prefWidth="1526.0" styleClass="table-frame">
         <children>
            <TableView fx:id="coursesTable" prefHeight="604.0" prefWidth="1526.0">
               <columns>
                  <TableColumn fx:id="colCourseId" prefWidth="98.0" text="COURSE ID" />
                  <TableColumn fx:id="colCourseName" minWidth="0.0" prefWidth="201.0" text="COURSE NAME" />
                  <TableColumn fx:id="colMajor" prefWidth="164.0" text="MAJOR" />
                  <TableColumn fx:id="colCredits" prefWidth="113.0" text="CREDITS" />
                  <TableColumn fx:id="colInstructor" prefWidth="169.0" sortable="false" text="INSTRUCTOR" />
                  <TableColumn fx:id="colCapacity" minWidth="0.0" prefWidth="183.0" text="CAPACITY" />
                  <TableColumn fx:id="colEnrolled" prefWidth="138.0" text="ENROLLED" />
                  <TableColumn fx:id="colPrerequisites" prefWidth="178.0" text="PREQUISTS" />
                  <TableColumn fx:id="colStatus" prefWidth="133.0" text="STATUS" />
                  <TableColumn fx:id="colActions" prefWidth="308.0" text="ACTION" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </children>
   <stylesheets>
      <URL value="@../../theme.css" />
      <URL value="@../../../../example/student_uifx/theme.css" />
   </stylesheets>
</AnchorPane>

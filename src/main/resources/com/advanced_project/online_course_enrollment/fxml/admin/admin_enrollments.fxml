<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" maxWidth="Infinity" prefHeight="900.0" prefWidth="2225.0" spacing="26.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advanced_project.online_course_enrollment.controller.AdminEnrollmentsController">
    <children>
        <VBox maxWidth="1410" spacing="28.0">
            <children>

                        <Label fx:id="enrollmentMessageLabel" managed="false" text="" visible="false" />

                <VBox minHeight="720.0" spacing="0.0" styleClass="admin-card">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="enrollment-registry-header">
                            <children>
                                <TextField fx:id="searchField" prefHeight="49.0" prefWidth="920.0" promptText="Search students or courses..." styleClass="enrollment-search" HBox.hgrow="ALWAYS" />
                                <Label fx:id="registryCountLabel" managed="false" styleClass="enrollment-count-pill" text="0" visible="false" />
                            </children>
                        </HBox>
                        <Separator />
                        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="enrollment-filter-bar">
                            <children>
                                <Label styleClass="enrollment-field-label" text="FILTER BY" />
                                <ComboBox fx:id="studentFilterComboBox" opacity="0.65" prefHeight="50.0" prefWidth="230.0" promptText="All students" />
                                <ComboBox fx:id="courseFilterComboBox" opacity="0.65" prefHeight="50.0" prefWidth="250.0" promptText="All courses" />
                                <ComboBox fx:id="statusFilterComboBox" opacity="0.65" prefHeight="50.0" prefWidth="200.0" promptText="All statuses" />
                                <ComboBox fx:id="majorFilterComboBox" opacity="0.65" prefHeight="50.0" prefWidth="210.0" promptText="All majors" />
                                <ComboBox fx:id="yearFilterComboBox" opacity="0.65" prefHeight="50.0" prefWidth="150.0" promptText="All years" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#clearFilters" prefHeight="50.0" styleClass="btn-secondary" text="Clear" />
                            </children>
                        </HBox>
                        <TableView fx:id="enrollmentsTable" prefHeight="604.0" prefWidth="2400" styleClass="enrollment-table">
                            <columns>
                                <TableColumn fx:id="studentColumn" prefWidth="210.0" text="STUDENT" />
                                <TableColumn fx:id="courseColumn" prefWidth="255.0" text="COURSE" />
                                <TableColumn fx:id="majorColumn" prefWidth="160.0" text="MAJOR" />
                                <TableColumn fx:id="yearColumn" prefWidth="70.0" text="YEAR" />
                                <TableColumn fx:id="gpaColumn" prefWidth="70.0" text="GPA" />
                                <TableColumn fx:id="creditsColumn" prefWidth="85.0" text="CREDITS" />
                                <TableColumn fx:id="enrolledAtColumn" prefWidth="185.0" text="ENROLLED AT" />
                                <TableColumn fx:id="statusColumn" prefWidth="125.0" text="STATUS" />
                                <TableColumn fx:id="actionsColumn" prefWidth="260.0" text="ACTIONS" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
    <padding>
        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
    </padding>
</VBox>

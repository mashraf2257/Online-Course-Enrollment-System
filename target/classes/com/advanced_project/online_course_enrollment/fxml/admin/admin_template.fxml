<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="1000" prefWidth="1850.0" styleClass="scene-root" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advanced_project.online_course_enrollment.controller.AdminTemplateController">
    <stylesheets>
        <URL value="@../../theme.css" />
    </stylesheets>
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar">
            <children>
                <HBox alignment="CENTER" style="-fx-padding: 10 0 20 0;">
                    <children>
                        <ImageView fitHeight="120.0" fitWidth="180.0" preserveRatio="true" styleClass="brand-logo">
                            <image>
                                <Image url="@../../../../example/student_uifx/Icons/logolight.png" />
                            </image>
                        </ImageView>
                    </children>
                </HBox>

                <Button onAction="#showDashboard" styleClass="nav-item" text="Dashboard">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" preserveRatio="true" styleClass="nav-icon">
                            <image>
                                <Image url="@../../Icons/menu.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                <Button onAction="#showStudents" styleClass="nav-item" text="Manage Students">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" preserveRatio="true" styleClass="nav-icon">
                            <image>
                                <Image url="@../../Icons/graduation.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                <Button onAction="#showCourses" styleClass="nav-item" text="Manage Courses">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" preserveRatio="true" styleClass="nav-icon">
                            <image>
                                <Image url="@../../Icons/book.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                <Button onAction="#showEnrollments" styleClass="nav-item" text="Mangage Enrollments">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" preserveRatio="true" styleClass="nav-icon">
                            <image>
                                <Image url="@../../Icons/shopping-cart.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                <Button onAction="#showRecommendations" styleClass="nav-item" text="Recommendations">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" preserveRatio="true" styleClass="nav-icon">
                            <image>
                                <Image url="@../../../../example/student_uifx/Icons/ai-technology.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <Button styleClass="nav-item nav-item-bottom" text="System Settings">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" preserveRatio="true" styleClass="nav-icon">
                            <image>
                                <Image url="@../../Icons/settings.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                <Button onAction="#handleSignOut" styleClass="nav-item nav-item-bottom" text="Sign Out">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" preserveRatio="true" styleClass="nav-icon">
                            <image>
                                <Image url="@../../Icons/logout.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
            </children>
        </VBox>
    </left>
    <center>
        <VBox alignment="TOP_CENTER" spacing="12.0" styleClass="content">
            <padding>
                <Insets bottom="14.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="12.0" styleClass="admin-page-top-bar">
                    <children>
                        <ImageView fx:id="pageTitleIcon" fitHeight="38.0" fitWidth="38.0" preserveRatio="true" />
                        <Label fx:id="pageTitleLabel" styleClass="admin-page-top-title" text="Dashboard" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="admin-page-user-name" text="Admin" />
                        <ImageView fitHeight="62.0" fitWidth="62.0" preserveRatio="true" styleClass="admin-page-user-avatar">
                            <image>
                                <Image url="@../../../../example/student_uifx/Icons/man.png" />
                            </image>
                        </ImageView>
                    </children>
                </HBox>
                <VBox fx:id="contentArea" alignment="TOP_CENTER" spacing="12.0" />
            </children>
        </VBox>
    </center>
</BorderPane>
